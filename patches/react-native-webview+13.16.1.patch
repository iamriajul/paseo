+package com.reactnativecommunity.webview;
+
+class RNCProxyAuthCredential {
+    String host;
+    String realm;
+    String username;
+    String password;
+
+    RNCProxyAuthCredential(String host, String realm, String username, String password) {
+        this.host = host;
+        this.realm = realm;
+        this.username = username;
+        this.password = password;
+    }
+
+    boolean matches(String challengeHost, String challengeRealm) {
+        return host.equalsIgnoreCase(challengeHost) && realm.equals(challengeRealm);
+    }
+}
